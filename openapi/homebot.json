{
  "openapi": "3.1.1",
  "info": {
    "title": "homebot | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/api/widgets/cards": {
      "get": {
        "tags": [
          "homebot"
        ],
        "operationId": "GetWidgetCards",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WidgetSnapshotDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/widgets/actions": {
      "post": {
        "tags": [
          "homebot"
        ],
        "operationId": "ExecuteWidgetAction",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ActionRequestDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActionResponseDto"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ActionItem": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "url": {
            "type": [
              "null",
              "string"
            ],
            "format": "uri"
          },
          "id": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ActionRequestDto": {
        "required": [
          "actionId",
          "label",
          "parameter"
        ],
        "type": "object",
        "properties": {
          "actionId": {
            "type": "string"
          },
          "label": {
            "type": [
              "null",
              "string"
            ]
          },
          "parameter": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ActionResponseDto": {
        "required": [
          "success",
          "message",
          "updatedCard"
        ],
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": [
              "null",
              "string"
            ]
          },
          "updatedCard": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Card"
              }
            ]
          }
        }
      },
      "Card": {
        "type": "object",
        "properties": {
          "heading": {
            "type": [
              "null",
              "string"
            ]
          },
          "summary": {
            "type": [
              "null",
              "string"
            ]
          },
          "accent": {
            "type": [
              "null",
              "string"
            ]
          },
          "link": {
            "type": [
              "null",
              "string"
            ],
            "format": "uri"
          },
          "createdAt": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "content": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContentBlock"
            }
          },
          "actions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ActionItem"
            }
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          }
        }
      },
      "ContentBlock": {
        "required": [
