            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KeyValueItem"
            }
          }
        }
      },
      "ContentBlockListBlock": {
        "properties": {
          "type": {
            "enum": [
              "list"
            ],
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ContentBlockMediaBlock": {
        "properties": {
          "type": {
            "enum": [
              "media"
            ],
            "type": "string"
          },
          "source": {
            "type": "string",
            "format": "uri"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ContentBlockTextBlock": {
        "properties": {
          "type": {
            "enum": [
