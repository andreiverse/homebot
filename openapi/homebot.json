          {
            "$ref": "#/components/schemas/ContentBlockTextBlock"
          },
          {
            "$ref": "#/components/schemas/ContentBlockKeyValueBlock"
          },
          {
            "$ref": "#/components/schemas/ContentBlockMediaBlock"
          },
          {
            "$ref": "#/components/schemas/ContentBlockListBlock"
          },
          {
            "$ref": "#/components/schemas/ContentBlockCodeBlock"
          },
          {
            "$ref": "#/components/schemas/ContentBlockDividerBlock"
          },
          {
            "$ref": "#/components/schemas/ContentBlockGraphBlock"
          }
        ],
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "text": "#/components/schemas/ContentBlockTextBlock",
            "keyValue": "#/components/schemas/ContentBlockKeyValueBlock",
            "media": "#/components/schemas/ContentBlockMediaBlock",
            "list": "#/components/schemas/ContentBlockListBlock",
            "code": "#/components/schemas/ContentBlockCodeBlock",
            "divider": "#/components/schemas/ContentBlockDividerBlock",
            "graph": "#/components/schemas/ContentBlockGraphBlock"
          }
        }
      },
      "ContentBlockCodeBlock": {
        "properties": {
          "type": {
            "enum": [
              "code"
