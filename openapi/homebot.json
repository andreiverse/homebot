              "graph"
            ],
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "xLabel": {
            "type": "string"
          },
          "yLabel": {
            "type": "string"
          },
          "isDateTimeAxis": {
            "type": "boolean"
          },
          "series": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GraphSeries"
            }
          }
        }
      },
      "ContentBlockKeyValueBlock": {
        "properties": {
